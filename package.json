    "eslint": "^9.39.0",
    "homebridge": "^2.0.0-beta.0",
    "nodemon": "^3.1.0",
    "rimraf": "^6.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.46.0"
  }
